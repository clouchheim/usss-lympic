# Copy this file to .env and fill in your own values. Never commit the real .env file.

# Your Lympik profile UUID (find it under My profile > Edit data in app.lympik.com).
# Used as the HTTP Basic auth username.
LYMPIK_PROFILE_ID=''

# Your Lympik personal API key (My profile > Edit data > Reset API key in app.lympik.com).
# Shown only once when generated. Used as the HTTP Basic auth password.
LYMPIK_API_KEY=''

# UUID of a Lympik event you host or participate in. The API has no
# "list my events" endpoint, so you need to already know which event to inspect.
LYMPIK_EVENT_ID=''

# Optional override, defaults to https://api.lympik.com/v1
LYMPIK_BASE_URL=https://api.lympik.com/v1

# USSS's Teamworks AMS instance base URL. Not a secret -- already hardcoded
# as the default in teamworks_client.py, so this only needs to be set to
# point at a different instance (e.g. a sandbox for testing).
TEAMWORKS_BASE_URL=https://usopc.smartabase.com/athlete360-usss

# Teamworks AMS API account credentials (HTTP Basic Auth, v1 endpoints only).
TEAMWORKS_USERNAME=''
TEAMWORKS_PASSWORD=''

# Optional. Identifies this integration to Teamworks support. Defaults to
# "usss.lympik-integration" if unset.
TEAMWORKS_APP_ID=usss.lympik-integration

# IANA timezone used to convert Lympik's unix timestamps into Teamworks
# AMS's dd/MM/yyyy and h:mm AM/PM date/time strings. Defaults to Mountain
# Time (handles MST/MDT automatically) if unset.
PIPELINE_TIMEZONE=America/Denver

