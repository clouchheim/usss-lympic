# Copy this file to .env and fill in your own values. Never commit the real .env file.

# Your Lympik profile UUID (find it under My profile > Edit data in app.lympik.com).
# Used as the HTTP Basic auth username.
LYMPIK_PROFILE_ID=

# Your Lympik personal API key (My profile > Edit data > Reset API key in app.lympik.com).
# Shown only once when generated. Used as the HTTP Basic auth password.
LYMPIK_API_KEY=

# UUID of a Lympik event you host or participate in. The API has no
# "list my events" endpoint, so you need to already know which event to inspect.
LYMPIK_EVENT_ID=

# Optional override, defaults to https://api.lympik.com/v1
LYMPIK_BASE_URL=https://api.lympik.com/v1
